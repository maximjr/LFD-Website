{
  "entities": {
    "Subscription": {
      "title": "Subscription",
      "description": "A subscription request for Optimal Healthcare services.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the subscription." },
        "name": { "type": "string", "description": "Full name of the subscriber." },
        "email": { "type": "string", "format": "email", "description": "Email address of the subscriber." },
        "phone": { "type": "string", "description": "Phone number of the subscriber." },
        "planType": { "type": "string", "enum": ["monthly", "yearly"], "description": "Type of subscription plan." },
        "paymentMethod": { "type": "string", "description": "Method used for payment." },
        "status": { "type": "string", "enum": ["pending", "active", "expired"], "description": "Current status of the subscription." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the subscription request was created." },
        "startDate": { "type": "string", "format": "date-time", "description": "When the subscription was activated." },
        "expiryDate": { "type": "string", "format": "date-time", "description": "When the subscription expires." }
      },
      "required": ["name", "email", "phone", "planType", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile with role information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role for access control." }
      },
      "required": ["email", "role"]
    },
    "ActivationKey": {
      "title": "ActivationKey",
      "description": "Unique activation key for a specific user and plan.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the key." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "plan": { "type": "string", "enum": ["monthly", "yearly"], "description": "Subscription plan associated with the key." },
        "durationDays": { "type": "integer", "description": "Duration of the subscription in days." },
        "key": { "type": "string", "description": "The unique activation key." },
        "status": { "type": "string", "enum": ["unused", "used"], "description": "Current status of the key." },
        "emailSent": { "type": "boolean", "description": "Whether the activation email has been sent." },
        "emailSentAt": { "type": "string", "format": "date-time", "description": "When the activation email was sent." },
        "emailAttempts": { "type": "integer", "description": "Number of email delivery attempts." },
        "emailStatus": { "type": "string", "enum": ["pending", "sent", "retrying", "failed"], "description": "Current status of email delivery." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the key was generated." },
        "expiresAt": { "type": "string", "format": "date-time", "description": "When the subscription expires after activation." }
      },
      "required": ["userId", "email", "plan", "durationDays", "key", "status", "createdAt"]
    },
    "MaintenanceLog": {
      "title": "MaintenanceLog",
      "description": "Log of automated maintenance operations.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time", "description": "When the maintenance ran." },
        "actionsPerformed": { "type": "array", "items": { "type": "string" }, "description": "List of actions performed." },
        "errorsFound": { "type": "array", "items": { "type": "string" }, "description": "List of errors encountered." },
        "fixesApplied": { "type": "array", "items": { "type": "string" }, "description": "List of fixes applied." }
      },
      "required": ["date", "actionsPerformed", "errorsFound", "fixesApplied"]
    },
    "StreamConfig": {
      "title": "StreamConfig",
      "description": "Live stream configuration and status for YouTube Live.",
      "type": "object",
      "properties": {
        "streamTitle": { "type": "string" },
        "streamDescription": { "type": "string" },
        "youtubeVideoId": { "type": "string" },
        "streamStatus": { "type": "string", "enum": ["offline", "scheduled", "live", "ended"] },
        "isSeminarActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["streamTitle", "streamStatus"]
    },
    "ActivationCode": {
      "title": "ActivationCode",
      "description": "Hashed activation code for subscription verification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "activationCode": { "type": "string", "description": "Bcrypt hashed activation code." },
        "subscriptionId": { "type": "string" },
        "subscriptionStatus": { "type": "string" },
        "activationStatus": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expirationTime": { "type": "string", "format": "date-time" },
        "attempts": { "type": "integer" }
      },
      "required": ["userId", "email", "activationCode", "subscriptionId", "activationStatus", "createdAt", "expirationTime"]
    },
    "Seminar": {
      "title": "Seminar",
      "description": "A scheduled health seminar or training program.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "integer" },
        "speaker": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["scheduled", "live", "ended", "cancelled"] },
        "youtubeVideoId": { "type": "string" },
        "notificationsSent": { "type": "boolean", "description": "Whether upcoming notifications have been sent." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startTime", "status", "createdAt"]
    },
    "Content": {
      "title": "Content",
      "description": "New health content or resources added to the platform.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "video", "guide", "resource"] },
        "url": { "type": "string" },
        "notificationsSent": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "createdAt"]
    },
    "SubscriptionRetryLog": {
      "title": "SubscriptionRetryLog",
      "description": "Log of failed subscription retry attempts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subscriptionId": { "type": "string" },
        "attemptNumber": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "retrying", "success", "failed"] },
        "errorMessage": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "nextRetryAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subscriptionId", "attemptNumber", "status", "timestamp"]
    }
  },
  "firestore": {
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Collection of subscription requests."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and roles."
    },
    "/activationKeys/{keyId}": {
      "schema": "ActivationKey",
      "description": "Collection of user-specific activation keys."
    },
    "/maintenanceLogs/{logId}": {
      "schema": "MaintenanceLog",
      "description": "Collection of automated maintenance logs."
    },
    "/streamConfig/{docId}": {
      "schema": "StreamConfig",
      "description": "Collection containing the singleton stream configuration."
    },
    "/activationCodes/{codeId}": {
      "schema": "ActivationCode",
      "description": "Collection of hashed activation codes."
    },
    "/seminars/{seminarId}": {
      "schema": "Seminar",
      "description": "Collection of scheduled seminars."
    },
    "/content/{contentId}": {
      "schema": "Content",
      "description": "Collection of new health content and resources."
    },
    "/subscriptionRetryLogs/{logId}": {
      "schema": "SubscriptionRetryLog",
      "description": "Collection of subscription retry logs."
    }
  }
}
